{
  "compilerOptions": {
    "baseUrl": "./",
    "composite": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "importHelpers": true,
    "isolatedModules": true,
    "lib": ["es2022"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "noEmitOnError": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "es2022",
    "customConditions": ["team-ai"],
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "paths": {
      "@features/project-conversations": [
        "libs/frontend/features/project-conversations/src/index.ts"
      ],
      "@features/project-conversations/*": [
        "libs/frontend/features/project-conversations/src/*"
      ],
      "@features/projects": [
        "libs/frontend/features/projects/src/index.ts"
      ],
      "@features/projects/*": [
        "libs/frontend/features/projects/src/*"
      ],
      "@shared/ui": ["libs/frontend/shared/ui/src/index.ts"],
      "@shared/ui/*": ["libs/frontend/shared/ui/src/*"],
      "@shared/util-http": ["libs/frontend/shared/util-http/src/index.ts"],
      "@shared/util-http/*": ["libs/frontend/shared/util-http/src/*"]
    }
  }
}
