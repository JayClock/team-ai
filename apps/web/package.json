{
  "name": "@web/main",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "dependencies": {
    "@features/conversation-messages": "workspace:*",
    "@features/project-conversations": "workspace:*",
    "@shared/util-http": "workspace:*",
    "@features/user-projects": "workspace:*",
    "@shells/layout": "workspace:*"
  },
  "nx": {
    "projectType": "application",
    "tags": [
      "type:app"
    ],
    "targets": {
      "dev": {
        "dependsOn": [
          ":apps:server:bootRun"
        ]
      },
      "docker:build": {
        "dependsOn": [
          "build"
        ],
        "inputs": [
          "production",
          "^production"
        ],
        "executor": "nx:run-commands",
        "options": {
          "cwd": "apps/web",
          "command": "docker build . --tag teamai/web:${VERSION:-latest}"
        }
      },
      "docker:run": {
        "dependsOn": [
          "docker:build"
        ],
        "inputs": [
          "production",
          "^production"
        ],
        "executor": "nx:run-commands",
        "options": {
          "cwd": "apps/web",
          "command": "docker run {args} teamai/web:${VERSION:-latest}"
        }
      }
    }
  }
}
