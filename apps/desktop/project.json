{
  "name": "desktop",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/desktop/src",
  "projectType": "application",
  "tags": ["type:app"],
  "targets": {
    "build": {
      "executor": "nx-electron:build",
      "dependsOn": ["local-server:build", "@agent-gateway/main:build"],
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/apps/desktop",
        "deleteOutputPath": true,
        "main": "apps/desktop/src/main.ts",
        "tsConfig": "apps/desktop/tsconfig.app.json",
        "assets": [
          "apps/desktop/src/assets",
          {
            "input": "apps/local-server/dist",
            "glob": "**/*",
            "output": "local-server"
          },
          {
            "input": "apps/agent-gateway/dist",
            "glob": "**/*",
            "output": "agent-gateway"
          }
        ]
      },
      "configurations": {
        "production": {
          "optimization": true,
          "extractLicenses": true,
          "inspect": false,
          "fileReplacements": [
            {
              "replace": "apps/desktop/src/environments/environment.ts",
              "with": "apps/desktop/src/environments/environment.prod.ts"
            }
          ]
        }
      }
    },
    "serve": {
      "executor": "nx-electron:execute",
      "dependsOn": ["@web/main:serve"],
      "options": {
        "buildTarget": "desktop:build"
      }
    },
    "package": {
      "executor": "nx-electron:package",
      "dependsOn": ["build"],
      "options": {
        "name": "desktop",
        "frontendProject": "@web/main",
        "sourcePath": "dist/apps",
        "outputPath": "dist/packages",
        "prepackageOnly": true
      }
    },
    "make": {
      "executor": "nx-electron:make",
      "dependsOn": ["build"],
      "options": {
        "name": "desktop",
        "frontendProject": "@web/main",
        "sourcePath": "dist/apps",
        "outputPath": "dist/executables"
      }
    },
    "lint": {
      "command": "eslint apps/desktop/**/*.ts"
    }
  }
}
